PORT=8080
# Socket.IO CORS (tùy chọn). Cách nhau bằng dấu phẩy; để trống thì dùng danh sách mặc định trong utils/socket.js
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MONGODB_URI=mongodb://127.0.0.1:27017/techhome

# Tin nhắn hỗ trợ / góp ý sản phẩm — id user ADMIN nhận chat (tuỳ chọn; không set thì chọn ADMIN id nhỏ nhất)
# SUPPORT_ADMIN_USER_ID=1
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# Avatar — Cloudflare R2 (bucket + r2.dev + CORS đã tạo qua API). Còn thiếu: R2 API token → điền 2 dòng AWS_* bên dưới (Dashboard → R2 → Manage R2 API Tokens).
S3_BUCKET=student-project-assets
S3_REGION=auto
S3_ENDPOINT=https://a0fbfef35f171fc3bd858423bf5cafed.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=526f5c1521a7050c520fded8b14f4ca9
AWS_SECRET_ACCESS_KEY=86b6f7ba1d9289f0d7a7557a7dedd4e533488e816142beee32f4c0f75f21a0c5
PUBLIC_ASSET_BASE_URL=https://pub-2388d4dd6b344edd8bb1ea8a27399754.r2.dev

# R2 dùng endpoint mặc định AWS SDK; không bật path style MinIO
# S3_FORCE_PATH_STYLE=
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=bd318f2f771f6c
MAIL_PASS=2aa7b7474c457f

# Phí ship: cố định (VND). Miễn phí khi tiền hàng sau giảm >= ngưỡng (0 = tắt miễn phí theo ngưỡng).
DEFAULT_SHIPPING_FEE=30000
FREE_SHIPPING_MIN_SUBTOTAL=500000

# Thanh toán: mặc định COD (thanh toán khi nhận hàng). Bật true để chỉ cho DELIVERED khi đã PAID
# (áp dụng đơn online; đơn COD được miễn — khi chuyển DELIVERED hệ thống tự ghi PAID + paidAt).
PAYMENT_REQUIRE_PAID_FOR_DELIVERED=false