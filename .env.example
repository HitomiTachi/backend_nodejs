PORT=8080
MONGODB_URI=mongodb://127.0.0.1:27017/techhome

# Link trong email quen mat khau (SPA). Mac dinh: hash router -> http://localhost:3000/#/reset-password/<token>
FRONTEND_URL=http://localhost:3000
# Dat 0 hoac false neu frontend dung BrowserRouter (khong co # trong URL)
# FRONTEND_USE_HASH_ROUTER=1
# Thoi gian hieu luc token dat lai mat khau (phut)
# PASSWORD_RESET_EXPIRES_MINUTES=60

# JWT RS256 keys (PEM), su dung chuoi 1 dong voi \n
JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n<replace-with-private-key>\n-----END PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n<replace-with-public-key>\n-----END PUBLIC KEY-----

# Khuyen nghi production: doc key tu file path (uu tien hon bien PEM o tren)
# JWT_PRIVATE_KEY_PATH=/run/secrets/jwt-private.pem
# JWT_PUBLIC_KEY_PATH=/run/secrets/jwt-public.pem

# Avatar: presigned PUT len S3-compatible (AWS S3, Cloudflare R2, MinIO)
# AVATAR_STRICT_PUBLIC_PREFIX=1 — chi cho phep avatarUrl cung prefix PUBLIC_ASSET_BASE_URL (R2/CDN); mac dinh tat
# Chi tiet R2: docs/R2_CLOUDFLARE_SETUP.md (bat R2 trong Dashboard truoc, loi 10042 neu chua bat)
# PUBLIC_ASSET_BASE_URL = prefix public doc anh, khong co / cuoi (phai khop key sau upload)
# R2: https://pub-xxxxx.r2.dev/ten-bucket  hoac theo GET .../domains/managed
# S3_ENDPOINT: AWS de trong; R2 = https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# S3_REGION: R2 dung auto; AWS tuy vung
# S3_FORCE_PATH_STYLE=true cho MinIO
# Bucket: CORS cho PUT tu http://localhost:3000
# S3_BUCKET=
# S3_REGION=auto
# S3_ENDPOINT=
# S3_FORCE_PATH_STYLE=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# PUBLIC_ASSET_BASE_URL=
